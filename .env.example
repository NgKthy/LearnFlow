# -----------------------------------------------------------------------------
# Personal LMS - Environment Variables Template (.env.example)
# -----------------------------------------------------------------------------
# Copy this file to '.env' or '.env.local' and adjust variables as needed.

# Database Connections (Prisma)
# - For PostgreSQL (e.g. Supabase, Neon):
DATABASE_URL="postgresql://username:password@localhost:5432/learnflow?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/learnflow?schema=public"

# Telegram Bot Integration
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# AI Provider Settings (Gemini / Google AI SDK)
AI_PROVIDER="google"
AI_MODEL="gemini-1.5-flash"
GOOGLE_GENERATIVE_AI_API_KEY="your_google_ai_api_key_here"
